{
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "STLAF.API",
    "Audience": "STLAF.Client",
    "DurationInMinutes": 480
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "https://stlaf-ithelpdesk.vercel.app/api"
  ],
  "AllowedHosts": "*"
}